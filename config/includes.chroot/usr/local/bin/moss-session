#!/usr/bin/env bash
set -Eeuo pipefail
CFG_DIR="$HOME/.config/debianmoss"
CFG_FILE="$CFG_DIR/session"
mkdir -p "$CFG_DIR"
usage() {
  cat <<'EOT'
Usage:
  moss-session show
  moss-session status
  moss-session use xfce
  moss-session use openbox
  moss-session use custom "my-wm --flag"
EOT
}
cmd="${1:-show}"
case "$cmd" in
  show|status)
    if [[ -f "$CFG_FILE" ]]; then cat "$CFG_FILE"; else echo startxfce4; fi ;;
  use)
    target="${2:-}"
    case "$target" in
      xfce) echo startxfce4 > "$CFG_FILE" ;;
      openbox) echo openbox-session > "$CFG_FILE" ;;
      custom) shift 2; [[ $# -gt 0 ]] || { usage >&2; exit 1; }; printf '%s\n' "$*" > "$CFG_FILE" ;;
      *) usage >&2; exit 1 ;;
    esac
    echo "Saved session command to $CFG_FILE" ;;
  *) usage >&2; exit 1 ;;
esac
